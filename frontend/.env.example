# ═══════════════════════════════════════════════════════════════
# AMO CARTAGENA — Frontend Environment Variables
# Copy to .env.local and fill in real values.
# All EXPO_PUBLIC_* vars are inlined into the JS bundle at build time.
# ═══════════════════════════════════════════════════════════════

# ── Backend API ──────────────────────────────────────────────
EXPO_PUBLIC_BACKEND_URL=https://api.amocartagena.app

# ── App Public URL ───────────────────────────────────────────
EXPO_PUBLIC_APP_URL=https://amocartagena.co

# ── AI Enrichment Proxy (optional — search works without it) ─
EXPO_PUBLIC_AI_PROXY_URL=

# ── WhatsApp Concierge ───────────────────────────────────────
EXPO_PUBLIC_AMO_WHATSAPP=573176481183
