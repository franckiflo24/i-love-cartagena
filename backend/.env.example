# AMO Cartagena Backend — Required Environment Variables

# MongoDB
MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net
DB_NAME=amo_cartagena

# AI / LLM
ANTHROPIC_API_KEY=sk-ant-...
EMERGENT_LLM_KEY=your-emergent-key

# Admin Operator (REQUIRED — no defaults)
ADMIN_OPERATOR_PASSWORD=set-a-strong-password
ADMIN_TOKEN_SECRET=set-a-random-secret-string

# Wompi Payments
WOMPI_ENV=sandbox
WOMPI_PUBLIC_KEY=pub_test_...
WOMPI_PRIVATE_KEY=prv_test_...
WOMPI_EVENTS_SECRET=your-webhook-secret
WOMPI_INTEGRITY_SECRET=your-integrity-secret
APP_COMMISSION_PCT=3
RESERVATION_COMMISSION_PCT=5

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8081,https://amocartagena.co

# App URL (used for activation links)
PUBLIC_APP_URL=https://amocartagena.co

# Google (geocoding)
GOOGLE_API_KEY=your-google-api-key

# Push Notifications
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send
EXPO_PUSH_TIMEOUT=10

# Business Account Seeding (optional — skips if missing)
DEMO_PARTNER_PASSWORD=
ALCALDIA_PASSWORD=

# Feature Flags (demo only — NEVER enable in production)
# MOCK_PAY=1
# PORT_TAX_AUTO_PAY=1
# SEED_RESET=1
